generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile       Profile?
  foodLogs      FoodLog[]
  weightLogs    WeightLog[]
  customFoods   Food[]
  favoriteMeals FavoriteMeal[]
  waterLogs     WaterLog[]
  weeklyCheckIns WeeklyCheckIn[]
}

model Profile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  age            Int?
  gender         String?
  heightCm       Float?
  currentWeight  Float?
  goalWeight     Float?
  activityLevel  String?
  goal           String?

  bmr            Float?
  tdee           Float?
  calorieTarget  Int?
  proteinTarget  Int?
  carbTarget     Int?
  fatTarget      Int?

  adaptiveCalories     Int?
  lastAdaptiveCheck    DateTime?
  adaptiveAdjustments  Int      @default(0)

  waterGoal         Int?      // ml per day; null = auto-calculated from stats
  proteinPreference String?   // 'low' | 'moderate' | 'high' | 'athletic'

  updatedAt      DateTime @updatedAt
}

model Food {
  id          String   @id @default(cuid())
  name        String
  brand       String?
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  fiber       Float?
  sodium      Float?
  servingSize Float    @default(100)
  servingUnit String   @default("g")
  isCustom    Boolean  @default(false)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  logEntries          FoodLogEntry[]
  favoriteEntries     FavoriteMealEntry[]

  @@index([name])
  @@index([userId])
}

model FoodLog {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime       @db.Date
  entries   FoodLogEntry[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // Condensed totals — populated when entries older than 90 days are rolled up
  condensedCalories Int?
  condensedProtein  Float?
  condensedCarbs    Float?
  condensedFat      Float?
  condensedAt       DateTime?

  @@unique([userId, date])
  @@index([userId, date])
}

model FoodLogEntry {
  id          String   @id @default(cuid())
  foodLogId   String
  foodLog     FoodLog  @relation(fields: [foodLogId], references: [id], onDelete: Cascade)
  foodId      String
  food        Food     @relation(fields: [foodId], references: [id])
  meal        String
  servings    Float    @default(1)
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  fiber       Float?
  sodium      Float?
  createdAt   DateTime @default(now())

  @@index([foodLogId])
}

model WeightLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weight    Float
  date      DateTime @db.Date
  note      String?
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

model FavoriteMeal {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  meal      String
  entries   FavoriteMealEntry[]
  createdAt DateTime            @default(now())

  @@index([userId])
}

model FavoriteMealEntry {
  id             String       @id @default(cuid())
  favoriteMealId String
  favoriteMeal   FavoriteMeal @relation(fields: [favoriteMealId], references: [id], onDelete: Cascade)
  foodId         String
  food           Food         @relation(fields: [foodId], references: [id])
  servings       Float        @default(1)
}

model WaterLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  amount    Int
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

model WeeklyCheckIn {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  recommendation String   // cut | add | maintain | water_weight | refeed | insufficient_data
  adjustment     Int      @default(0)   // kcal delta (positive = add, negative = cut)
  reasoning      String   // short display label
  weeklyChange   Float?   // actual lbs/week (negative = losing)
  expectedChange Float    @default(0)   // expected lbs/week

  status         String   @default("pending")  // pending | accepted | rejected
  caloriesBefore Int?
  caloriesAfter  Int?

  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}
